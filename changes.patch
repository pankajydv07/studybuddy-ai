import os
import pytest
from pathlib import Path


class TestReadme:
    """Tests for README documentation updates."""
    
    @pytest.fixture
    def readme_path(self):
        """Return the path to the README file."""
        # Assuming README is in project root
        return Path(__file__).parent.parent / "README.md"
    
    def test_readme_file_exists(self, readme_path):
        """Verify README.md exists in the repository."""
        assert readme_path.exists(), "README.md file should exist"
        assert readme_path.is_file(), "README should be a file"
    
    def test_readme_not_empty(self, readme_path):
        """Verify README.md is not empty."""
        content = readme_path.read_text(encoding='utf-8')
        assert len(content.strip()) > 0, "README.md should not be empty"
    
    def test_readme_contains_title(self, readme_path):
        """Verify README contains a title/header."""
        content = readme_path.read_text(encoding='utf-8')
        assert content.strip().startswith('#'), "README should start with a markdown header"
    
    def test_readme_contains_required_sections(self, readme_path):
        """Verify README contains standard sections."""
        content = readme_path.read_text(encoding='utf-8').lower()
        required_sections = ['installation', 'usage', 'features']
        
        for section in required_sections:
            assert section in content, f"README should contain '{section}' section"
    
    def test_readme_no_broken_links(self, readme_path):
        """Verify README markdown links are properly formatted."""
        import re
        content = readme_path.read_text(encoding='utf-8')
        
        # Check for markdown links [text](url)
        link_pattern = r'\[([^\]]+)\]\(([^)]+)\)'
        links = re.findall(link_pattern, content)
        
        for text, url in links:
            # Skip anchor links and relative paths for this basic test
            if url.startswith('http'):
                assert not url.endswith(' '), f"Link URL should not end with space: {url}"
                assert ' ' not in url, f"Link URL should not contain spaces: {url}"


class TestDocumentationIntegration:
    """Integration tests for documentation updates."""
    
    def test_readme_references_correct_version(self):
        """Verify README references match package version if applicable."""
        # This test assumes there's a version file or package to check against
        try:
            from studybuddy_ai import __version__ as package_version
            readme_content = Path("README.md").read_text()
            
            # Check if version is mentioned in README
            if package_version in readme_content:
                assert True, "Version is documented in README"
        except ImportError:
            pytest.skip("Package version not available for comparison")
    
    def test_readme_images_exist(self):
        """Verify any referenced images in README exist."""
        import re
        readme_path = Path(__file__).parent.parent / "README.md"
        content = readme_path.read_text()
        
        # Find image references ![alt](path)
        img_pattern = r'!\[([^\]]*)\]\(([^)]+)\)'
        images = re.findall(img_pattern, content)
        
        for alt, path in images:
            if not path.startswith('http'):  # Skip external URLs
                img_path = readme_path.parent / path
                assert img_path.exists(), f"Referenced image should exist: {path}"