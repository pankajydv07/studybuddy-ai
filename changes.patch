class TestLinkExtractor:
    """Tests for LinkExtractor class."""
    
    def test_extract_links_from_text(self):
        """Test extracting URLs from text content."""
        text = "Check out https://example.com and http://test.org for more info."
        extractor = LinkExtractor()
        links = extractor.extract_links(text)
        
        assert len(links) == 2
        assert "https://example.com" in links
        assert "http://test.org" in links
    
    def test_extract_links_removes_duplicates(self):
        """Test that duplicate URLs are removed."""
        text = "Visit https://example.com and https://example.com again."
        extractor = LinkExtractor()
        links = extractor.extract_links(text)
        
        assert len(links) == 1
        assert links[0] == "https://example.com"
    
    def test_extract_links_empty_text(self):
        """Test extracting from empty text."""
        extractor = LinkExtractor()
        links = extractor.extract_links("")
        
        assert links == []
    
    def test_extract_links_no_urls(self):
        """Test text with no URLs."""
        text = "This is just plain text without any links."
        extractor = LinkExtractor()
        links = extractor.extract_links(text)
        
        assert links == []
    
    def test_extract_from_attachments_with_link(self):
        """Test extracting links from attachment objects."""
        attachments = [
            {'link': {'url': 'https://example.com/doc'}},
            {'link': {'url': 'https://another.com/file'}}
        ]
        extractor = LinkExtractor()
        links = extractor.extract_from_attachments(attachments)
        
        assert len(links) == 2
        assert "https://example.com/doc" in links
    
    def test_extract_from_attachments_with_drivefile(self):
        """Test extracting Google Drive links from attachments."""
        attachments = [
            {'driveFile': {'alternateLink': 'https://drive.google.com/file/d/123'}},
            {'link': {'url': 'https://example.com'}}
        ]
        extractor = LinkExtractor()
        links = extractor.extract_from_attachments(attachments)
        
        assert len(links) == 2
        assert "https://drive.google.com/file/d/123" in links
    
    def test_extract_from_attachments_empty(self):
        """Test extracting from empty attachments list."""
        extractor = LinkExtractor()
        links = extractor.extract_from_attachments([])
        
        assert links == []
    
    def test_extract_from_attachments_mixed_types(self):
        """Test extracting from attachments with mixed types and missing data."""
        attachments = [
            {'link': {'url': 'https://example.com'}},
            {'driveFile': {}},  # Missing alternateLink
            {},  # Empty attachment
            {'youtubeVideo': {'id': 'abc123'}}  # Unsupported type
        ]
        extractor = LinkExtractor()
        links = extractor.extract_from_attachments(attachments)
        
        assert len(links) == 1
        assert links[0] == "https://example.com"


class TestContentFetcher:
    """Tests for ContentFetcher class."""
    
    @patch('studybuddy.content_fetcher.requests.Session')
    def test_fetch_content_success(self, mock_session_class):
        """Test successful content fetching."""
        # Setup mock
        mock_session = MagicMock()
        mock_session_class.return_value = mock_session
        
        mock_response = MagicMock()
        mock_response.content = b'<html><head><title>Test Page</title></head><body><p>Hello World</p></body></html>'
        mock_response.raise_for_status = Mock()
        mock_session.get.return_value = mock_response
        
        fetcher = ContentFetcher()
        result = fetcher.fetch_content("https://example.com")
        
        assert result is not None
        assert result['url'] == "https://example.com"
        assert result['title'] == "Test Page"
        assert "Hello World" in result['content']
        assert result['domain'] == "example.com"
    
    def test_fetch_content_google_drive(self):
        """Test handling of Google Drive URLs."""
        fetcher = ContentFetcher()
        result = fetcher.fetch_content("https://drive.google.com/file/d/123/view")
        
        assert result is not None
        assert result['title'] == "Google Drive File"
        assert "drive.google.com" in result['content']
        assert result['domain'] == "drive.google.com"
    
    def test_fetch_content_google_docs(self):
        """Test handling of Google Docs URLs."""
        fetcher = ContentFetcher()
        result = fetcher.fetch_content("https://docs.google.com/document/d/123/edit")
        
        assert result is not None
        assert result['title'] == "Google Drive File"
    
    @patch('studybuddy.content_fetcher.requests.Session')
    def test_fetch_content_request_error(self, mock_session_class):
        """Test handling of request errors."""
        mock_session = MagicMock()
        mock_session_class.return_value = mock_session
        mock_session.get.side_effect = requests.RequestException("Connection error")
        
        fetcher = ContentFetcher()
        result = fetcher.fetch_content("https://example.com")
        
        assert result is None
    
    @patch('studybuddy.content_fetcher.requests.Session')
    def test_fetch_content_timeout(self, mock_session_class):
        """Test handling of timeout."""
        mock_session = MagicMock()
        mock_session_class.return_value = mock_session
        mock_session.get.side_effect = requests.Timeout("Request timed out")
        
        fetcher = ContentFetcher(timeout=5)
        result = fetcher.fetch_content("https://example.com")
        
        assert result is None
    
    @patch.object(ContentFetcher, 'fetch_content')
    def test_fetch_multiple(self, mock_fetch):
        """Test fetching multiple URLs."""
        mock_fetch.side_effect = [
            {'url': 'https://example.com', 'title': 'Example', 'content': 'Content', 'domain': 'example.com'},
            {'url': 'https://test.org', 'title': 'Test', 'content': 'Test Content', 'domain': 'test.org'},
            None  # One failure
        ]
        
        fetcher = ContentFetcher()
        results = fetcher.fetch_multiple(['https://example.com', 'https://test.org', 'https://fail.com'])
        
        assert len(results) == 2
        assert results[0]['title'] == 'Example'
        assert results[1]['title'] == 'Test'
    
    def test_fetch_multiple_empty_list(self):
        """Test fetching with empty URL list."""
        fetcher = ContentFetcher()
        results = fetcher.fetch_multiple([])
        
        assert results == []


class TestFormatForAI:
    """Tests for format_for_ai function."""
    
    def test_format_for_ai(self):
        """Test formatting sources for AI context."""
        sources = [
            {'url': 'https://example.com', 'title': 'Example', 'content': 'Content here'},
            {'url': 'https://test.org', 'title': 'Test', 'content': 'Test content'}
        ]
        
        result = format_for_ai(sources)
        
        assert "Source 1: Example (https://example.com)" in result
        assert "Content here" in result
        assert "Source 2: Test (https://test.org)" in result
        assert "---" in result
    
    def test_format_for_ai_empty(self):
        """Test formatting with empty sources."""
        result = format_for_ai([])
        
        assert result == ""
    
    def test_format_for_ai_single_source(self):
        """Test formatting with single source."""
        sources = [{'url': 'https://example.com', 'title': 'Example', 'content': 'Content'}]
        
        result = format_for_ai(sources)
        
        assert "Source 1:" in result
        assert "---" not in result  # No separator for single item


