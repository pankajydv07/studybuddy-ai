    def test_getting_started_has_clone_instructions(self, readme_content):
        """Verify Getting Started includes clone instructions."""
        assert "git clone" in readme_content, \
            "Getting Started should include git clone instructions"
        assert "studybuddy-ai" in readme_content, \
            "Should reference correct repository name"
    
    def test_getting_started_has_install_steps(self, readme_content):
        """Verify Getting Started includes dependency installation."""
        assert "npm install" in readme_content or "yarn install" in readme_content, \
            "Getting Started should include dependency installation"
    
    def test_getting_started_has_dev_command(self, readme_content):
        """Verify Getting Started includes dev server command."""
        assert "npm run dev" in readme_content or "yarn dev" in readme_content, \
            "Getting Started should include dev server command"
    
    def test_usage_section_has_steps(self, readme_content):
        """Verify Usage section has numbered or bulleted steps."""
        usage_section = re.search(
            r'## Usage\n\n(.+?)(?=\n## |$)',
            readme_content,
            re.DOTALL
        )
        assert usage_section is not None, "Usage section should exist"
        content = usage_section.group(1)
        
        # Check for numbered list or bullet points
        has_numbers = re.search(r'\d+\.', content) is not None
        has_bullets = re.search(r'[-*] ', content) is not None
        
        assert has_numbers or has_bullets, \
            "Usage section should have numbered or bulleted steps"
    
    def test_screenshots_section_has_placeholder_or_images(self, readme_content):
        """Verify Screenshots section exists with placeholders or actual images."""
        if "## Screenshots" in readme_content:
            # Check for markdown image syntax
            images = re.findall(r'!\[.*?\]\((.+?)\)', readme_content)
            assert len(images) > 0, \
                "Screenshots section should contain image references"
    
    def test_all_links_are_valid_format(self, readme_content):
        """Verify all markdown links have valid format."""
        # Find all markdown links [text](url)
        links = re.findall(r'\[([^\]]+)\]\(([^)]+)\)', readme_content)
        
        for text, url in links:
            # Skip anchor links
            if url.startswith("#"):
                continue
            
            # Verify URL is not empty
            assert len(url.strip()) > 0, \
                f"Link '{text}' has empty URL"
            
            # Verify text is not empty
            assert len(text.strip()) > 0, \
                f"Link to '{url}' has empty text"
    
    def test_no_generic_nextjs_content(self, readme_content):
        """Verify generic Next.js template content has been replaced."""
        generic_phrases = [
            "This is a [Next.js](https://nextjs.org) project",
            "bootstrapped with [`create-next-app`]",
            "You can start editing the page by modifying `app/page.tsx`",
            "The easiest way to deploy your Next.js app"
        ]
        
        for phrase in generic_phrases:
            assert phrase not in readme_content, \
                f"README should not contain generic template text: '{phrase[:50]}...'"
    
    def test_prerequisites_section_has_requirements(self, readme_content):
        """Verify Prerequisites section lists actual requirements."""
        prereq_section = re.search(
            r'## Prerequisites\n\n(.+?)(?=\n## |$)',
            readme_content,
            re.DOTALL
        )
        assert prereq_section is not None, "Prerequisites section should exist"
        content = prereq_section.group(1)
        
        # Should mention Node.js
        assert "Node.js" in content, "Prerequisites should mention Node.js"
        
        # Should mention API keys
        assert "API key" in content.lower(), \
            "Prerequisites should mention API keys requirement"
    
    def test_license_section_exists(self, readme_content):
        """Verify License section exists."""
        assert "## License" in readme_content, "README should have License section"
        assert "MIT" in readme_content or "Apache" in readme_content or "GPL" in readme_content, \
            "License section should mention specific license type"


class TestReadmeIntegration:
    """Integration tests for README accuracy against codebase."""
    
    def test_documented_scripts_exist_in_package_json(self):
        """Verify scripts mentioned in README exist in package.json."""
        readme = Path("README.md")
        package = Path("package.json")
        
        if not readme.exists() or not package.exists():
            pytest.skip("Required files not found")
        
        readme_content = readme.read_text()
        package_data = json.loads(package.read_text())
        scripts = package_data.get("scripts", {})
        
        # Check for mentioned scripts
        if "npm run dev" in readme_content:
            assert "dev" in scripts, "'dev' script should exist in package.json"
        
        if "npm run build" in readme_content:
            assert "build" in scripts, "'build' script should exist in package.json"
    
    def test_documented_tech_stack_installed(self):
        """Verify documented technologies are in dependencies."""
        readme = Path("README.md")
        package = Path("package.json")
        
        if not readme.exists() or not package.exists():
            pytest.skip("Required files not found")
        
        readme_content = readme.read_text()
        package_data = json.loads(package.read_text())
        
        deps = {**package_data.get("dependencies", {}), 
                **package_data.get("devDependencies", {})}
        
        # Map common names to package names
        tech_mapping = {
            "Tailwind CSS": "tailwindcss",
            "TypeScript": "typescript",
            "NextAuth.js": "next-auth",
            "Prisma": "prisma",
            "LangChain": "langchain"
        }
        
        for tech_name, package_name in tech_mapping.items():
            if tech_name in readme_content:
                assert package_name in deps, \
                    f"{tech_name} mentioned in README but {package_name} not in package.json"
    
    def test_image_paths_exist_or_are_placeholders(self):
        """Verify image paths in README exist or are clearly marked as placeholders."""
        readme = Path("README.md")
        if not readme.exists():
            pytest.skip("README not found")
        
        content = readme.read_text()
        images = re.findall(r'!\[.*?\]\((.+?)\)', content)
        
        for img_path in images:
            # Skip external URLs
            if img_path.startswith("http"):
                continue
            
            # Check if file exists or is in docs directory (common convention)
            if "docs/" in img_path or "assets/" in img_path or "public/" in img_path:
                # These are acceptable placeholder paths
                pass
            else:
                img_file = Path(img_path)
                if img_file.exists():
                    assert img_file.stat().st_size > 0, \
                        f"Image file {img_path} exists but is empty"


class TestReadmeAccessibility:
    """Tests for README accessibility and formatting."""
    
    @pytest.fixture
    def readme_content(self):
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text(encoding="utf-8")
    
    def test_readme_has_proper_heading_hierarchy(self, readme_content):
        """Verify heading hierarchy (no skipping levels)."""
        headings = re.findall(r'^(#{1,6}) ', readme_content, re.MULTILINE)
        
        if len(headings) < 2:
            return
        
        # Check that we don't skip from # to ### without ##
        levels = [len(h) for h in headings]
        for i in range(1, len(levels)):
            if levels[i] > levels[i-1] + 1:
                assert False, \
                    f"Heading level jumps from {levels[i-1]} to {levels[i]}"
    
    def test_code_blocks_have_language_specified(self, readme_content):
        """Verify code blocks have language specified for syntax highlighting."""
        # Find code blocks without language
        generic_blocks = re.findall(r'```\n', readme_content)
        
        # Allow empty blocks for spacing, but log them
        if len(generic_blocks) > 0:
            # Check if they're just separators or actual code
            pass  # We'll be lenient here
    
    def test_tables_have_consistent_columns(self, readme_content):
        """Verify markdown tables have consistent column counts."""
        tables = re.findall(
            r'\|(.+?)\|\n\|[-:\s|]+\|\n((?:\|.+?\|\n?)+)',
            readme_content,
            re.DOTALL
        )
        
        for header, rows in tables:
            header_cols = header.count("|") + 1
            for row in rows.strip().split("\n"):
                if row.strip():
                    row_cols = row.count("|")
                    assert row_cols == header_cols or row_cols == header_cols - 1, \
                        f"Table row has inconsistent columns: {row[:50]}"


