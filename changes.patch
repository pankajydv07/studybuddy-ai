import pytest
import re
import json
from pathlib import Path
from typing import List, Tuple


class TestReadmeStructure:
    """Tests for README.md structure and content validation."""
    
    @pytest.fixture
    def readme_content(self):
        """Load README.md content."""
        readme_path = Path("README.md")
        if not readme_path.exists():
            pytest.skip("README.md not found")
        return readme_path.read_text(encoding="utf-8")
    
    @pytest.fixture
    def package_json(self):
        """Load package.json for dependency validation."""
        package_path = Path("package.json")
        if not package_path.exists():
            return {}
        return json.loads(package_path.read_text())
    
    def test_readme_has_project_title(self, readme_content):
        """Verify README starts with project title."""
        assert readme_content.startswith("# StudyBuddy AI"), \
            "README should start with '# StudyBuddy AI' title"
    
    def test_readme_has_description(self, readme_content):
        """Verify README contains project description."""
        assert "AI-powered study assistant" in readme_content, \
            "README should contain project description"
    
    def test_readme_has_required_sections(self, readme_content):
        """Verify all required sections exist in README."""
        required_sections = [
            "## Features",
            "## Tech Stack",
            "## Prerequisites",
            "## Getting Started",
            "## Environment Variables",
            "## Usage",
            "## Deployment"
        ]
        for section in required_sections:
            assert section in readme_content, \
                f"README missing required section: {section}"
    
    def test_features_section_has_content(self, readme_content):
        """Verify Features section has actual content."""
        features_match = re.search(
            r'## Features\n\n(.+?)(?=\n## |$)',
            readme_content,
            re.DOTALL
        )
        assert features_match is not None, "Features section should have content"
        content = features_match.group(1)
        assert len(content.strip()) > 50, "Features section should be substantive"
        
        # Check for specific features mentioned
        expected_features = [
            "AI-Powered",
            "Quiz",
            "Study",
            "Document"
        ]
        for feature in expected_features:
            assert feature in content, f"Features should mention {feature}"
    
    def test_tech_stack_matches_dependencies(self, readme_content, package_json):
        """Verify Tech Stack section mentions technologies in package.json."""
        if not package_json:
            pytest.skip("package.json not found")
        
        dependencies = package_json.get("dependencies", {})
        dev_dependencies = package_json.get("devDependencies", {})
        all_deps = {**dependencies, **dev_dependencies}
        
        # Check that mentioned technologies are in dependencies
        tech_stack_section = re.search(
            r'## Tech Stack\n\n(.+?)(?=\n## |$)',
            readme_content,
            re.DOTALL
        )
        if tech_stack_section:
            content = tech_stack_section.group(1)
            
            # If Next.js is mentioned, verify it's in dependencies
            if "Next.js" in content:
                assert "next" in all_deps, \
                    "Next.js mentioned in Tech Stack but not in package.json"
            
            if "Tailwind" in content:
                assert "tailwindcss" in all_deps, \
                    "Tailwind mentioned in Tech Stack but not in package.json"
    
    def test_environment_variables_documented(self, readme_content):
        """Verify Environment Variables section has table format."""
        env_section = re.search(
            r'## Environment Variables\n\n(.+?)(?=\n## |$)',
            readme_content,
            re.DOTALL
        )
        assert env_section is not None, "Environment Variables section should exist"
        content = env_section.group(1)
        
        # Check for table format
        assert "| Variable |" in content, "Environment Variables should be in table format"
        assert "OPENAI_API_KEY" in content, "Should document OPENAI_API_KEY"
    
    def test_env_example_exists_if_referenced(self, readme_content):
        """Verify .env.example exists if referenced in setup instructions."""
        if ".env.example" in readme_content:
            env_example = Path(".env.example")
            assert env_example.exists(), \
                "README references .env.example but file doesn't exist"
    
