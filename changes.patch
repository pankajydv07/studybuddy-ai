    @patch.object(ClassroomClient, '_extract_links_from_announcement')
    def test_get_announcements_adds_extracted_links(self, mock_extract, classroom_client):
        """Test that get_announcements adds _extracted_links field."""
        client, mock_service = classroom_client
        
        mock_extract.return_value = ['https://example.com']
        
        # Mock the API response
        mock_courses = MagicMock()
        mock_announcements = MagicMock()
        mock_list = MagicMock()
        mock_execute = MagicMock()
        
        mock_execute.execute.return_value = {
            'announcements': [
                {'id': '1', 'text': 'Hello'},
                {'id': '2', 'text': 'World'}
            ]
        }
        mock_list.list.return_value = mock_execute
        mock_announcements.announcements.return_value = mock_list
        mock_courses.courses.return_value = mock_announcements
        mock_service.courses = mock_courses
        
        # Need to re-patch the service
        with patch.object(client, 'courses', mock_courses):
            announcements = client.get_announcements('course123')
        
        assert len(announcements) == 2
        assert '_extracted_links' in announcements[0]
        assert announcements[0]['_extracted_links'] == ['https://example.com']
    
    def test_fetch_link_contents(self, classroom_client):
        """Test fetching link contents from course item."""
        client, _ = classroom_client
        
        course_item = {
            '_extracted_links': ['https://example.com', 'https://test.org']
        }
        
        with patch.object(client.content_fetcher, 'fetch_multiple') as mock_fetch:
            mock_fetch.return_value = [
                {'url': 'https://example.com', 'content': 'Example content'}
            ]
            results = client.fetch_link_contents(course_item)
        
        mock_fetch.assert_called_once_with(['https://example.com', 'https://test.org'])
        assert len(results) == 1
    
    def test_fetch_link_contents_no_links(self, classroom_client):
        """Test fetching when no links present."""
        client, _ = classroom_client
        
        course_item = {}
        results = client.fetch_link_contents(course_item)
        
        assert results == []


class TestStudyBuddyAI:
