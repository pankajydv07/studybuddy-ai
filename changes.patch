    @patch('studybuddy.ai_bot.openai.ChatCompletion.create')
    def test_ask_api_error(self, mock_create, ai_bot):
        """Test handling of API errors."""
        mock_create.side_effect = Exception("API Error")
        
        response = ai_bot.ask("Question")
        
        assert "Sorry" in response
        assert "trouble" in response.lower()


class TestIntegration:
    """Integration tests for the full workflow."""
    
    @patch('studybuddy.content_fetcher.requests.Session')
    @patch('studybuddy.ai_bot.openai.ChatCompletion.create')
    def test_full_workflow(self, mock_openai, mock_session_class):
        """Test complete workflow from link extraction to AI response."""
        # Setup content fetcher mock
        mock_session = MagicMock()
        mock_session_class.return_value = mock_session
        mock_response = MagicMock()
        mock_response.content = b'<html><title>Test</title><body>Content</body></html>'
        mock_response.raise_for_status = Mock()
        mock_session.get.return_value = mock_response
        
        # Setup OpenAI mock
        mock_openai.return_value = {
            'choices': [{'message': {'content': 'AI analyzed the content'}}]
        }
        
        # 1. Extract links
        extractor = LinkExtractor()
        text = "Check https://example.com"
        links = extractor.extract_links(text)
        
        # 2. Fetch content
        fetcher = ContentFetcher()
        contents = fetcher.fetch_multiple(links)
        
        # 3. Format for AI
        context = format_for_ai(contents)
        
        # 4. Ask AI
        ai = StudyBuddyAI(api_key='test')
        ai.add_link_context(contents)
        response = ai.ask("What is this?")
        
        assert response == "AI analyzed the content"
        assert len(contents) > 0